{
  "name": "ollama-paperclip-adapter",
  "version": "0.1.0",
  "description": "Paperclip external adapter for local Ollama models",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "paperclip": {
